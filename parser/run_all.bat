@echo off
REM Агрегатный импорт всех данных план-факта со шары Бюджета:
REM   * помесячная история статусов помещений (Сдан / Не сдан)
REM   * съезды/заезды арендаторов (из листа «4 съезд-заезд»)
REM
REM Подходит для Windows Task Scheduler — раз в неделю или после правок
REM в файлах руководством. Идемпотентный: повторный запуск ничего не
REM ломает, только обновляет данные.

setlocal
cd /d "%~dp0"

REM Если на машине нужны явные creds для шары Acad-server — подцепляем.
if exist "%~dp0..\.creds.bat" call "%~dp0..\.creds.bat"

python -X utf8 -u run_all.py %*

exit /b %ERRORLEVEL%
