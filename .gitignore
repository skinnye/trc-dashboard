# ── Секреты ──────────────────────────────────────────────────────────
# Пароли MSSQL и пути к сетевым шарам — только локально.
.env
.env.local
.env.*.local
*.key
*.pem

# ── Данные ───────────────────────────────────────────────────────────
# SQLite-снапшот пересоздаётся при первом запуске на новой машине.
dashboard.db
dashboard.db-journal
dashboard.db-wal
dashboard.db-shm

# ── Node / Next.js ───────────────────────────────────────────────────
node_modules/
.next/
out/
*.tsbuildinfo
next-env.d.ts

# ── Логи ─────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Системное ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── Архив старого Python-стека ───────────────────────────────────────
# Хранится локально на случай отката, в репо не нужно.
_old/

# ── Claude Code ──────────────────────────────────────────────────────
# Локальные настройки и кэш агента — нужны только на dev-машине.
.claude/

# ── Бизнес-данные (Excel) ────────────────────────────────────────────
# Файлы лежат на сетевой шаре или в /Desktop, в репо не должны попадать.
/*.xlsx
/*.xls
/*.rar
/*.exe

# ── Сетевые credentials (локальный файл) ────────────────────────────
# .creds.bat содержит net use с паролем для шары Acad-server.
# Файл создаётся вручную на каждой машине, в репо не попадает.
.creds.bat

# ── Парсер: локальные артефакты ──────────────────────────────────────
# Логи прогонов и сырые JSON-выгрузки — за пределы машины не нужны.
parser/logs/
parser/raw/
parser/*.log

# Python байткод
__pycache__/
*.pyc
*.pyo

# vendor-parser-2gis это git-clone сторонней библиотеки (interlark/parser-2gis),
# ставится через `pip install -e ./vendor-parser-2gis` локально.
# В репо сам исходник не тащим — на другой машине склонировать вручную.
parser/vendor-parser-2gis/
